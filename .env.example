# ===========================================
#  Orhun AI Admin Panel — Environment Config
# ===========================================
# Bu faylni `.env` ga nusxalang va qiymatlarni toʻldiring.
# `.env` git'ga yuklanmaydi (.gitignore'da).

# --- Supabase (frontend bilan bir xil DB) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Python REST API (Oracle Ubuntu server) ---
# IP geolocation, multi-account detection, email yuborish va h.k. uchun.
# Faza 7'da toʻliq ishlatiladi. Hozir boʻsh qoldirilsa, API chaqiriqlari xato beradi
# (lekin boshqa boʻlimlar normal ishlaydi).
VITE_PYTHON_API_URL=https://api.your-server.com
